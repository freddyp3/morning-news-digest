    {
      "parameters": {
        "jsCode": "// take the data turn it into a string\nconst html = $input.all()[0].json.data;\n\nconst index = html.indexOf(\"<h2>Most Read</h2>\");\nconst end = html.indexOf(\"<h2>Guides</h2>\");\n\nconst content = html.substring(index, end)\n\n// regex to extract each article block\nconst matches = [...content.matchAll(\n  /<span class=\"prefix\">(\\d+)<\\/span>[\\s\\S]*?<a class=\"title accent-hover\" title=\"([^\"]+)\" href=\"([^\"]+)\">[\\s\\S]*?<span class=\"category accent\">([^<]+)<\\/span>/g\n)];\n\nconst results = matches.map(m => {\n  const rank = Number(m[1]);\n  const title = m[2]\n    .replace(/&amp;/g, \"&\")\n    .replace(/&quot;/g, '\"')\n    .replace(/&#39;/g, \"'\");\n\nconst link = m[3].startsWith(\"http\")\n  ? m[3]\n  : `https://www.nintendolife.com/${m[3]}`;\n  \n  const category = m[4];\n  \n  return {\n    rank,\n    title,\n    category,\n    link\n  };\n});\n\nreturn results.map(item => ({json: item}));"
      },
