      "parameters": {
        "jsCode": "// Loop over input items and add only news\nconst items = $input.all()[0].json.data.children\nconst result = []\n\nfor (const item of items) {\n  if (item.data.link_flair_text === \"News\") {\n    result.push(item)\n  }\n}\n\nreturn result"
      },
