    {
      "parameters": {
        "jsCode": "// Loop over items and find the block that matches current day\nconst date = new Date().toLocaleDateString('en-US', {weekday: 'long'});\nconst result = [];\nlet boolFlag = false;\n\nfor (const item of $input.all()) {\n  if (item.json.type === \"heading_2\" && boolFlag) {\n    break;\n  }\n  if (boolFlag === true) {\n    result.push({json : {task : item.json.content}});\n  }\n  if (item.json.type === \"heading_2\" && item.json.content === date) {\n    // start adding to the array\n    boolFlag = true;\n  }\n}\n\nreturn result;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        -112
      ],
      "id": "f4ba4254-7dc7-427b-a9a3-d094c1aa7ddb",
      "name": "Get TODOs by day"
    },
    {
      "parameters": {
        "jsCode": "// key: title, value: score\nconst result = new Map();\n\n// Initialize a map where all items have a score of 0\nfor (const item of $input.all()) {\n  result.set(item, 0);\n}\n\nconst high_keywords = [\n  \"ai\", \"artificial intelligence\", \"machine learning\", \"llm\", \"gpt\", \"claude\",\n  \"deep learning\", \"new tool\", \"launch\", \"release\", \"product\", \"research\",\n  \"paper\", \"breakthrough\", \"google\", \"apple\", \"microsoft\", \"meta\",\n  \"openai\", \"anthropic\", \"nvidia\", \"ai jobs\", \"hiring\", \"layoffs\",\n  \"job market\", \"intern\", \"new grad\", \"salary\", \"agentic\", \"harness\"\n];\n\nconst medium_keywords = [\n  \"open source\", \"open-source\", \"framework\", \"library\", \"python\", \"javascript\",\n  \"iphone\", \"macbook\", \"laptop\", \"phone\", \"pixel\", \"galaxy\",\n  \"regulation\", \"antitrust\", \"ai policy\", \"ban\", \"youtube algorithm\",\n  \"creator\", \"monetization\", \"platform\", \"breach\", \"hack\", \"data leak\"\n];\n\nconst exclude_keywords = [\n  \"startup funding\", \"series a\", \"raised\", \"venture capital\",\n  \"cryptocurrency\", \"crypto\", \"blockchain\", \"nft\", \"web3\"\n];\n\n// Filter -> Score\nfor (const item of $input.all()) {\n  const title = item.json.title;\n  \n  // hard excluding logic\n  for (const word of exclude_keywords) {\n    if (title.toLowerCase().includes(word)) {\n      result.delete(item);\n    }\n  }\n\n  // scoring logic HIGH\n  for (const word of high_keywords) {\n    if (title.toLowerCase().includes(word)) {\n      let score = result.get(item);\n      score += 3;\n      result.set(item, score);\n    }\n  }\n\n  // scoring logic MEDIUM\n  for (const word of medium_keywords) {\n    if (title.toLowerCase().includes(word)) {\n      let score = result.get(item);\n      score += 1;\n      result.set(item, score);\n    }\n  }\n\n}\n\nconst top2Titles = [...result.entries()]\n  .sort((a, b) => b[1] - a[1])\n  .slice(0, 2)\n  .map(([item]) => item);\n\nreturn top2Titles;"
      },
